void BRComputeDarbouxHessian(br_bristle *Bristle, mat3x3_f32 *DarbouxHessian[3])
{
    mat3x3_f32 PrevDarbouxHessian[BR_MAX_BRISTLE_SEGMENTS - 1][3];
    mat3x3_f32 NextDarbouxHessian[BR_MAX_BRISTLE_SEGMENTS - 1][3];

    // NOTE: X: 0 Y: 1 Z: 2
    mat3x3_f32 SkewTensor[3] = {0};
    SkewTensor[0].V[1][2] =  2.0f;
    SkewTensor[0].V[2][1] = -2.0f;
    SkewTensor[1].V[0][2] = -2.0f;
    SkewTensor[1].V[2][0] =  2.0f;
    SkewTensor[2].V[0][1] =  2.0f;
    SkewTensor[2].V[1][0] = -2.0f;

    mat3x3_f32 DarbouxGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeDarbouxGradient(Bristle, DarbouxGrad);

    mat3x3_f32 EdgeGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeEdgeGradient(Bristle, EdgeGrad);
    for(U32 Grad = 0; Grad < BR_MAX_BRISTLE_SEGMENTS - 1; ++Grad)
        EdgeGrad[Grad] = Transpose3x3F32(EdgeGrad[Grad]);
    
    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        mat3x3_f32 NumeratorDeriv[3] = {0};
        {
            mat3x3_f32 DarbouxResult[3] = {0};
            for(U32 k = 0; k < 3; ++k)
            {
                for(U32 j = 0; j < 3; ++j)
                {
                    for(U32 i = 0; i < 3; ++i)
                        DarbouxResult[k].V[i][j] = DarbouxGrad[Index].V[i][j] * Bristle->Edge[Index].V[j];
                }
            }

            mat3x3_f32 EdgeResult[3] = {0};
            for(U32 k = 0; k < 3; ++k)
            {
                for(U32 j = 0; j < 3; ++j)
                {
                    for(U32 i = 0; i < 3; ++i)
                        EdgeResult[k].V[i][j] = Bristle->Bishop[Index].Darboux.V[i] * EdgeGrad[Index].V[i][j];
                }
            }

            for(U32 k = 0; k < 3; ++k)
            {
                for(U32 j = 0; j < 3; ++j)
                {
                    for(U32 i = 0; i < 3; ++i)
                        NumeratorDeriv[k].V[i][j] = SkewTensor[k].V[i][j] + DarbouxResult[k].V[i][j] + EdgeResult[k].V[i][j];
                }
            }
        }
    }
}

void BRComputeEnergyHessian(br_bristle *Bristle, mat3x3_f32 *EnergyHessian[3])
{
    mat3x3_f32 DarbouxHessian[BR_MAX_BRISTLE_SEGMENTS - 1][3];
    BRComputeDarbouxHessian(Bristle, DarbouxHessian);
}

void BRUpdateBishop(br_bristle *Bristle)
{
    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        F32 Denominator = Bristle->SegmentLength * Bristle->SegmentLength + Dot3F32(Bristle->Edge[Index - 1], Bristle->Edge[Index]);
        Bristle->Bishop[Index].Darboux = Div3F32(Mul3F32(Vec3F32(2.0f, 2.0f, 2.0f), Cross3F32(Bristle->Edge[Index - 1], Bristle->Edge[Index])),
                                                 Vec3F32(Denominator, Denominator, Denominator));
    }

    Bristle->Bishop[0].u = Bristle->u0;
    Bristle->Bishop[0].v = Normalize3F32(Cross3F32(Bristle->Edge[0], Bristle->Bishop[0].u));

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        F32 Magnitude = Dot3F32(Bristle->Bishop[Index].Darboux, Bristle->Bishop[Index].Darboux);
        F32 CosPhi = SqrtF32(Max(4.0f / (4.0f + Magnitude), 0.0f));
        F32 SinPhi = SqrtF32(Max(Magnitude / (4.0f + Magnitude), 0.0f));
        Assert(CosPhi >= 0.0f && CosPhi <= 1.0f);
        if((1.0f - CosPhi) < F32Epsilon)
        {
            Bristle->Bishop[Index].u = Bristle->Bishop[Index - 1].u;
            Bristle->Bishop[Index].v = Bristle->Bishop[Index - 1].v;
            continue;
        }

        quat_f32 q = RealImaginaryQF32(CosPhi, Mul3F32(Vec3F32(SinPhi, SinPhi, SinPhi), Normalize3F32(Bristle->Bishop[Index].Darboux)));
        quat_f32 p = RealImaginaryQF32(0.0f, Bristle->Bishop[Index - 1].u);
        p = MulQF32(MulQF32(q, p), ConjugateQF32(q));

        Bristle->Bishop[Index].u = Normalize3F32(Vec3F32(p.X, p.Y, p.Z));
        Bristle->Bishop[Index].v = Normalize3F32(Cross3F32(Bristle->Edge[Index], Bristle->Bishop[Index].u));
    }
}

br_bristle BRBristleInit(F32 SegmentLength, U32 NumSegments)
{
    Assert(NumSegments <= BR_MAX_BRISTLE_SEGMENTS);
    
    br_bristle Bristle = {0};
    Bristle.SegmentLength = SegmentLength;
    Bristle.Count = NumSegments;
    Bristle.Alpha = 0.3f;
    Bristle.Beta = 0.3f;
    Bristle.B = Mat2x2F32(Bristle.Alpha);

    Bristle.u0 = Vec3F32(1.0f, 0.0f, 0.0f);
    
    for(U32 Index = 1; Index < NumSegments; ++Index)
        Bristle.Node[Index] = Add3F32(Bristle.Node[Index - 1], Vec3F32(0.0f, SegmentLength, 0.0f));
    BRUpdateEdges(&Bristle);
    
    BRUpdateBishop(&Bristle);
    
    return Bristle;
}

void BRBristleUpdateElasticForces(br_bristle *Bristle)
{
    Bristle->Node[Bristle->Count - 5].X = 1.0f;
    
    BRUpdateEdges(Bristle);
    BRUpdateBishop(Bristle);
    
    lbfgs_solver_params Solver = InitializeDefaultLBFGSParams();
    Solver.UserData = (void *)Bristle;
    F32 TwistEnergy = 0.0f;
    MinimizeLBFGS(Bristle->Theta, Bristle->Count - 1, &TwistEnergy, BRTwistEnergiesComputeFunctionAndGradient, &Solver);
    
    BRComputeMaterialFrameFromBishop(Bristle->Bishop, Bristle->Theta, Bristle->Material, Bristle->Count);

    vec3_f32 Forces[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeEnergyGradient(Bristle, Forces);

    mat3x3_f32 *EnergyHessian;
    BRComputeEnergyHessian(Bristle, EnergyHessian);

    Log("Forces!\n");
}
