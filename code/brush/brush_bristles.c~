#define BR_MAX_BRISTLE_SEGMENTS 32

typedef struct br_bishop_frame br_bishop_frame;
struct br_bishop_frame
{
    vec3_f32 u;
    vec3_f32 v;

    vec3_f32 Darboux;
};

typedef struct br_material_frame br_material_frame;
struct br_material_frame
{
    vec3_f32 m1;
    vec3_f32 m2;
};

typedef struct br_bristle br_bristle;
struct br_bristle
{
    // NOTE: The segments are considered to be of the same size and inextensible. Changing this functionality would require
    //       changing many of the functions below to work with varying segment lengths.
    F32 SegmentLength;
    
    U32 Count;
    F32 Beta;
    F32 Alpha;
    mat2x2_f32 B;
    vec3_f32 u0;
    
    vec3_f32 Node[BR_MAX_BRISTLE_SEGMENTS];
    vec3_f32 Edge[BR_MAX_BRISTLE_SEGMENTS - 1];
    br_bishop_frame Bishop[BR_MAX_BRISTLE_SEGMENTS - 1];
    F32 Theta[BR_MAX_BRISTLE_SEGMENTS - 1];
    br_material_frame Material[BR_MAX_BRISTLE_SEGMENTS - 1];
};

void BRUpdateEdges(br_bristle *Bristle)
{
    for(U32 EdgeIdx = 0; EdgeIdx < Bristle->Count - 1; ++EdgeIdx)
    {
        vec3_f32 *Edge = &Bristle->Edge[EdgeIdx];
        Bristle->Edge[EdgeIdx] = Sub3F32(Bristle->Node[EdgeIdx + 1], Bristle->Node[EdgeIdx]);
    }
}

void BRComputeMaterialFrameFromBishop(br_bishop_frame *Bishops, F32 *Thetas, br_material_frame *Materials, U32 Count)
{
    for(U32 Index = 0; Index < Count - 1; ++Index)
    {
        br_material_frame *Material = &Materials[Index];
        br_bishop_frame *Bishop = &Bishops[Index];

        F32 CosTheta = CosF32(Thetas[Index]);
        F32 SinTheta = SinF32(Thetas[Index]);
        
        Material->m1 = Add3F32(Mul3F32(Bishop->u, Vec3F32(CosTheta, CosTheta, CosTheta)), Mul3F32(Bishop->v, Vec3F32(SinTheta, SinTheta, SinTheta)));
        Material->m2 = Add3F32(Mul3F32(Bishop->u, Vec3F32(-SinTheta, -SinTheta, -SinTheta)), Mul3F32(Bishop->v, Vec3F32(CosTheta, CosTheta, CosTheta)));
    }
}

F32 BRComputeEnergy(br_bristle *Bristle, F32 *Theta, br_material_frame *Material)
{
    F32 Energy = 0.0f;
    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        // Bend energy term
        vec2_f32 W;
        W = Vec2F32(Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index - 1].m2),
                    -Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index - 1].m1));
        Energy += Dot2F32(W, Div2F32(Mul2F32(Mul2F32By2x2F32(Bristle->B, W), Vec2F32(0.5f, 0.5f)),
                                     Vec2F32(Bristle->SegmentLength, Bristle->SegmentLength)));

        W = Vec2F32(Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index].m2),
                    -Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index].m1));
        Energy += Dot2F32(W, Div2F32(Mul2F32(Mul2F32By2x2F32(Bristle->B, W), Vec2F32(0.5f, 0.5f)),
                                     Vec2F32(Bristle->SegmentLength, Bristle->SegmentLength)));
        
        // Twist energy term
        F32 mi = Theta[Index] - Theta[Index - 1];
        Energy += Bristle->Beta * mi * mi / Bristle->SegmentLength;
    }

    return Energy;
}

F32 BRTwistEnergiesComputeFunctionAndGradient(F32 *Vector, F32 *Gradient, U32 VectorSize, void *UserData)
{
    br_bristle *Bristle = (br_bristle *)UserData;

    br_material_frame Material[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeMaterialFrameFromBishop(Bristle->Bishop, Vector, Material, Bristle->Count);

    // Compute twist energy gradient:
    mat2x2_f32 JB = Mul2x2F32(Rotate2x2F32(0.25f), Bristle->B);
    for(U32 Index = 0; Index < Bristle->Count - 1; ++Index)
    {
        // Compute first term dWj/dQj + 2 * Beta * mj/lj
        if(Index > 0)
        {
            vec2_f32 W = Vec2F32(Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index].m2),
                                 -Dot3F32(Bristle->Bishop[Index].Darboux, Material[Index].m1));
        
            F32 Term = Dot2F32(W, Mul2F32By2x2F32(JB, W));
            Term += 2 * Bristle->Beta * (Vector[Index] - Vector[Index - 1]);
            Term /= Bristle->SegmentLength;

            Gradient[Index] += Term;
        }

        // Compute second term dWj+1/dQj - 2 * Beta * mj+1/lj+1
        if(Index < Bristle->Count - 2)
        {
            vec2_f32 W = Vec2F32(Dot3F32(Bristle->Bishop[Index + 1].Darboux, Material[Index].m2),
                                 -Dot3F32(Bristle->Bishop[Index + 1].Darboux, Material[Index].m1));

            F32 Term = Dot2F32(W, Mul2F32By2x2F32(JB, W));
            Term -= 2 * Bristle->Beta * (Vector[Index + 1] - Vector[Index]);
            Term /= Bristle->SegmentLength;

            Gradient[Index] += Term;
        }
    }

    // Compute energy function
    return BRComputeEnergy(Bristle, Vector, Material);
}

void BRComputeDarbouxGradient(br_bristle *Bristle, mat3x3_f32 *DarbouxGrad)
{
    mat3x3_f32 PrevDarbouxGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    mat3x3_f32 NextDarbouxGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    
    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        mat3x3_f32 Skew = {0};
        Skew.V[0][1] =  2.0f * Bristle->Edge[Index].Z;
        Skew.V[0][2] = -2.0f * Bristle->Edge[Index].Y;
        Skew.V[1][0] = -2.0f * Bristle->Edge[Index].Z;
        Skew.V[1][2] =  2.0f * Bristle->Edge[Index].X;
        Skew.V[2][0] =  2.0f * Bristle->Edge[Index].Y;
        Skew.V[2][1] = -2.0f * Bristle->Edge[Index].X;
        mat3x3_f32 Outer = Outer3F32(Bristle->Bishop[Index].Darboux, Bristle->Edge[Index]);

        F32 Denominator = Bristle->SegmentLength * Bristle->SegmentLength + Dot3F32(Bristle->Edge[Index - 1], Bristle->Edge[Index]);
        
        for(U32 j = 0; j < 3; ++j)
        {
            for(U32 i = 0; i < 3; ++i)
                PrevDarbouxGrad[Index].V[i][j] = (Outer.V[i][j] + Skew.V[i][j]) / Denominator;
        }
    }

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        mat3x3_f32 Skew = {0};
        Skew.V[0][1] =  2.0f * Bristle->Edge[Index - 1].Z;
        Skew.V[0][2] = -2.0f * Bristle->Edge[Index - 1].Y;
        Skew.V[1][0] = -2.0f * Bristle->Edge[Index - 1].Z;
        Skew.V[1][2] =  2.0f * Bristle->Edge[Index - 1].X;
        Skew.V[2][0] =  2.0f * Bristle->Edge[Index - 1].Y;
        Skew.V[2][1] = -2.0f * Bristle->Edge[Index - 1].X;
        mat3x3_f32 Outer = Outer3F32(Bristle->Bishop[Index].Darboux, Bristle->Edge[Index - 1]);

        F32 Denominator = Bristle->SegmentLength * Bristle->SegmentLength + Dot3F32(Bristle->Edge[Index - 1], Bristle->Edge[Index]);
        
        for(U32 j = 0; j < 3; ++j)
        {
            for(U32 i = 0; i < 3; ++i)
                NextDarbouxGrad[Index].V[i][j] = (Outer.V[i][j] + Skew.V[i][j]) / Denominator;
        }
    }

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        for(U32 j = 0; j < 3; ++j)
        {
            for(U32 i = 0; i < 3; ++i)
                DarbouxGrad[Index].V[i][j] = -(PrevDarbouxGrad[Index].V[i][j] + NextDarbouxGrad[Index].V[i][j]);
        }
    }
}

void BRComputeHolonomyGradient(br_bristle *Bristle, vec3_f32 *HolonomyGrad)
{
    vec3_f32 PrevHolonomyGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    vec3_f32 NextHolonomyGrad[BR_MAX_BRISTLE_SEGMENTS - 1];

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
    {
        F32 Denominator = 2.0f * Bristle->SegmentLength;
        PrevHolonomyGrad[Index] = Div3F32(Bristle->Bishop[Index].Darboux, Vec3F32(Denominator, Denominator, Denominator));
    }

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
        NextHolonomyGrad[Index] = Mul3F32(PrevHolonomyGrad[Index], Vec3F32(-1.0f, -1.0f, -1.0f));

    for(U32 Index = 1; Index < Bristle->Count - 1; ++Index)
        HolonomyGrad[Index] = Mul3F32(Add3F32(PrevHolonomyGrad[Index], NextHolonomyGrad[Index]), Vec3F32(-1.0f, -1.0f, -1.0f));
}

void BRComputeEnergyGradient(br_bristle *Bristle, vec3_f32 *EnergyGrad)
{
    mat3x3_f32 DarbouxGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeDarbouxGradient(Bristle, DarbouxGrad);

    vec3_f32 HolonomyGrad[BR_MAX_BRISTLE_SEGMENTS - 1];
    BRComputeHolonomyGradient(Bristle, HolonomyGrad);
    
    for(U32 Index = 0; Index < Bristle->Count - 1; ++Index)
    {
        F32 FirstScalar = (-2.0f * Bristle->Alpha) / Bristle->SegmentLength;
        vec3_f32 First = Mul3F32(Mul3F32By3x3F32(Transpose3x3F32(DarbouxGrad[Max(Index, 1)]), Bristle->Bishop[Max(Index, 1)].Darboux),
                                 Vec3F32(FirstScalar, FirstScalar, FirstScalar));
        F32 SecondScalar = (Bristle->Beta * (Bristle->Theta[Index] - Bristle->Theta[0])) / (Bristle->SegmentLength * Bristle->Count / 2.0f);
        vec3_f32 Second = Mul3F32(HolonomyGrad[Max(Index, 1)], Vec3F32(SecondScalar, SecondScalar, SecondScalar));

        EnergyGrad[Index] = Add3F32(First, Second);
    }
}

