        I64 Clamped = Range.X;
        UIScrollPtTargetIndex(Pt, Clamped);
    }
}

#define UIStackPushImpl(State, Stack, StackName, Element)   \
    {                                                       \
        Stack *Node = PushStruct(State->BuildArena, Stack); \
        Node->Data = Element;                               \
        SLLStackPush(State->StackName.Top, Node);           \
        State->StackName.AutoPop = 0;                       \
    }

#define UIStackPopImpl(State, StackName)        \
    {                                           \
        SLLStackPop(State->StackName.Top);      \
        State->StackName.AutoPop = 0;           \
    }

#define UIStackSetNextImpl(State, Stack, StackName, Element)    \
    {                                                           \
        Stack *Node = PushStruct(State->BuildArena, Stack);     \
        Node->Data = Element;                                   \
        SLLStackPush(State->StackName.Top, Node);               \
        State->StackName.AutoPop = 1;                           \
    }

