vec2_f32 UIBoxTextPosition(ui_box *Box)
{
    vec2_f32 Result = {0};
    font_handle Font = Box->Font;
    F32 FontSize = Box->FontSize;
    font_metrics FontMetrics = FontMetricsFromFontSize(Font, FontSize);
    Result.Y = CeilF32((Box->Rect.Top + Box->Rect.Bottom) / 2.0f + (FontMetrics.CapHeight / 2) - FontMetrics.LineGap / 2);

    switch(Box->TextAlign)
    {
        default:
        case UI_TEXT_ALIGNMENT_TYPE_LEFT:
        {
            Result.X = Box->Rect.Left + Box->TextPadding;
        }break;

        case UI_TEXT_ALIGNMENT_TYPE_CENTER:
        {
            vec2_f32 Advance = Box->StringRun.Dimensions;
            Result.X = (Box->Rect.Left + Box->Rect.Right) / 2 - Advance.X / 2;
            Result.X = ClampBot(Result.X, Box->Rect.Left);
        }break;

        case UI_TEXT_ALIGNMENT_TYPE_RIGHT:
        {
            vec2_f32 Advance = Box->StringRun.Dimensions;
            Result.X = (Box->Rect.Right) - 1.0f - Advance.X;
            Result.X = ClampBot(Result.X, Box->Rect.Left);
        }break;
    }

    Result.X = FloorF32(Result.X);
    return Result;
}

void UITooltipBeginBase()
{
    UIState->TooltipOpen = 1;
    UIPushParent(UIGetBoxRootFromState(UIState));
    UIPushParent(UIState->TooltipRoot);
    UIPushFlags(0);
}

void UITooltipEndBase()
{
    UIPopFlags();
    UIPopParent();
    UIPopParent();
}

void UITooltipBegin()
{
    UITooltipBeginBase();
    UISetNextSquish(0.25f - UIState->TooltipOpenT * 0.25f);
    UIFlags(UI_BOX_FLAG_DRAW_BORDER | UI_BOX_FLAG_DRAW_BACKGROUND)
        UIPrefWidth(UIChildrenSum(1.0f))
        UIPrefHeight(UIChildrenSum(1.0f))
        UICornerRadius(UITopFontSize() * 0.25f)
        UIColumnBegin();
    UIPrefWidth(UIPX(0.0f, 1.0f)) UISpacer(UIEM(0.5f, 1.0f));
    UIPrefWidth(UIChildrenSum(1.0f))
        UIPrefHeight(UIChildrenSum(1.0f))
        UIRowBegin();
    UIPrefHeight(UIPX(0.0f, 1.0f)) UISpacer(UIEM(0.5f, 1.0f));
    UIPrefWidth(UIChildrenSum(1.0f))
        UIPrefHeight(UIChildrenSum(1.0f))
        UIColumnBegin();
    UIPushPrefWidth(UITextDim(10.0f, 1.0f));
    UIPushPrefHeight(UIEM(2.0f, 1.0f));
    UIPushTextAlignment(UI_TEXT_ALIGNMENT_TYPE_CENTER);
}

void UITooltipEnd()
{
    UIPopTextAlignment();
    UIPopPrefWidth();
    UIPopPrefHeight();
    UIColumnEnd();
    UIPrefHeight(UIPX(0.0f, 1.0f)) UISpacer(UIEM(0.5f, 1.0f));
    UIRowEnd();
    UIPrefWidth(UIPX(0.0f, 1.0f)) UISpacer(UIEM(0.5f, 1.0f));
    UIColumnEnd();
    UITooltipEndBase();
}

