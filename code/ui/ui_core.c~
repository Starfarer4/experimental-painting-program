        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_ROUND_CHILD_BY_PARENT;
        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_DRAW_BACKGROUND;
        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_DRAW_BORDER;
        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_CLIP;
        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_CLICKABLE;
        UIState->CtxMenuRoot->Flags |= UI_BOX_FLAG_DRAW_BORDER_FOCUS;
        UIState->CtxMenuRoot->CornerRadii[0] = UIState->CtxMenuRoot->CornerRadii[1] = 
            UIState->CtxMenuRoot->CornerRadii[2] = UIState->CtxMenuRoot->CornerRadii[3] = UITopFontSize() * 0.25f;
        UIState->CtxMenuRoot->BackgroundColor = UITopBackgroundColor();
        UIState->CtxMenuRoot->BorderColor = UITopBorderColor();
