internal U8 ReadLE8(U8 **Bytes)
{
    U8 Result = **Bytes;
    *Bytes += 1;
    return Result;
}

internal U16 ReadLE16(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U16 Value = (Ptr[1] << 8) | Ptr[0];
    *Bytes += 2;
    return Value;
}

internal U32 ReadLE32(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U32 Value = (Ptr[3] << 24) | (Ptr[2] << 16) | (Ptr[1] << 8) | Ptr[0];
    *Bytes += 4;
    return Value;
}

internal U64 ReadLE64(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U64 Value = ((U64)Ptr[7] << 56) |
        ((U64)Ptr[6] << 48) |
        ((U64)Ptr[5] << 40) |
        ((U64)Ptr[4] << 32) |
        ((U64)Ptr[3] << 24) |
        ((U64)Ptr[2] << 16) |
        ((U64)Ptr[1] << 8)  |
        (U64)Ptr[0];
    *Bytes += 8;
    return Value;
}

internal U8 ReadBE8(U8 **Bytes)
{
    U8 Result = **Bytes;
    *Bytes += 1;
    return Result;
}

internal U16 ReadBE16(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U16 Value = (Ptr[0] << 8) | Ptr[1];
    *Bytes += 2;
    return Value;
}

internal U32 ReadBE32(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U32 Value = (Ptr[0] << 24) | (Ptr[1] << 16) | (Ptr[2] << 8) | Ptr[3];
    *Bytes += 4;
    return Value;
}

internal U64 ReadBE64(U8 **Bytes)
{
    U8 *Ptr = *Bytes;
    U64 Value = ((U64)Ptr[0] << 56) |
        ((U64)Ptr[1] << 48) |
        ((U64)Ptr[2] << 40) |
        ((U64)Ptr[3] << 32) |
        ((U64)Ptr[4] << 24) |
        ((U64)Ptr[5] << 16) |
        ((U64)Ptr[6] << 8)  |
        (U64)Ptr[7];
    *Bytes += 8;
    return Value;
}

// NOTE: Implements the FNV-1a hashing algorithm http://isthe.com/chongo/tech/comp/fnv/
internal U64 HashData(U8 *Bytes, U64 Size)
{
    const U64 FNVPrime = 1099511628211;
    U64 Hash = 14695981039346656037ul;
    for(;Size--; ++Bytes)
    {
        Hash ^= *Bytes;
        Hash *= FNVPrime;
    }
    return Hash;
}

#define HashStruct(Struct) HashData((U8 *)(Struct), sizeof(*(Struct)))
#define HashString(String) HashData((U8 *)(String), sizeof(String) - 1)

internal U16 SafeCastU16(U32 Var)
{
    Assert(Var <= U16Max);
    return (U16)Var;
}

internal U32 U32FromU64Satruate(U64 x)
{
    U32 x32 = (x > U32Max) ? U32Max : (U32)x;
    return x32;
}

