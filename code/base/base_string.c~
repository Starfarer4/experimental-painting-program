string8 Str8(U8 *String, U64 Size)
{
    string8 Result;
    Result.String = String;
    Result.Size = Size;
    return Result;
}

string8 PushStr8FmtV(arena *Arena, string8 Format, va_list Args)
{
    U8 *FormatCStr = PushArrayNoZero(Arena, U8, Format.Size + 1);
    MemoryCopy(FormatCStr, Format.String, Format.Size);
    FormatCStr[Format.Size] = '\0';
    
    va_list Args2;
    va_copy(Args2, Args);
    U32 NeededBytes = stbsp_vsnprintf(0, 0, FormatCStr, Args) + 1;
    string8 Result = {0};
    Result.String = PushArrayNoZero(Arena, U8, NeededBytes);
    Result.Size = stbsp_vsnprintf(Result.String, NeededBytes, FormatCStr, Args2);
    Result.String[Result.Size] = 0;
    va_end(Args2);
    return Result;
}

string8 PushStr8Fmt(arena *Arena, string8 Format, ...)
{
    va_list Args;
    va_start(Args, Format);
    string8 Result = PushStr8FmtV(Arena, Format, Args);
    va_end(Args);
    return Result;
}

string8 PushStr8Copy(arena *Arena, string8 String)
{
    string8 Result;
    Result.Size = String.Size;
    Result.String = PushArrayNoZero(Arena, U8, Result.Size + 1);
    MemoryCopy(Result.String, String.String, String.Size);
    Result.String[Result.Size] = 0;
    return Result;
    
}

string8 Str8Skip(string8 String, U64 Amount)
{
    Amount = ClampTop(Amount, String.Size);
    String.String += Amount;
    String.Size -= Amount;
    return (String);
}

unicode_decode Utf16Decode(U16 *String, U64 Max)
{
    unicode_decode Result;
    Result.Increment = 1;
    Result.Codepoint = String[0];
    if(Max > 1 && 0xD800 <= String[0] && String[0] < 0xDC00 && 0xDC00 <= String[1] && String[1] < 0xE000)
    {
        Result.Codepoint = ((String[0] - 0xD800) << 10) | (String[1] - 0xDC00) + 0x10000;
        Result.Increment = 2;
    }
    return Result;
}

U32 Utf8Encode(U8 *String, U32 Codepoint)
{
    U32 Increment =0;
    if(Codepoint <= 0x7F)
    {
        String[0] = (U8)Codepoint;
        Increment = 1;
    }
    else if(Codepoint <= 0x7FF)
    {
        String[0] = (0x00000003 << 6) | ((Codepoint >> 6) & 0x0000001F);
        String[1] = (1 << 7) | (Codepoint & 0x0000003F);
        Increment = 2;
    }
    else if(Codepoint <= 0xFFFF)
    {
        String[0] = (0x00000007 << 5) | ((Codepoint >> 12) & 0x0000000F);
        String[1] = (1 << 7) | ((Codepoint >> 6) & 0x0000003F);
        String[2] = (1 << 7) | (Codepoint & 0x0000003F);
        Increment = 3;
    }
    else if(Codepoint <= 0x10FFFF)
    {
        String[0] = (0x0000000F << 4) | ((Codepoint >> 18) & 0x00000007);
        String[1] = (1 << 7) | ((Codepoint >> 12) & 0x0000003F);
        String[2] = (1 << 7) | ((Codepoint >> 6) & 0x0000003F);
        String[3] = (1 << 7) | (Codepoint & 0x0000003F);
        Increment = 4;
    }
    else
    {
        String[0] = '?';
        Increment = 1;
    }
    
    return Increment;
}

string8 Str8From16(arena *Arena, string16 In)
{
    U64 Cap = In.Size * 3;
    U8 *String = PushArrayNoZero(Arena, U8, Cap + 1);
    U16 *Pointer = In.String;
    U16 *Opl = Pointer + In.Size;
    U64 Size = 0;
    unicode_decode Consume;
    
    for(;Pointer < Opl; Pointer += Consume.Increment)
    {
        Consume = Utf16Decode(Pointer, Opl - Pointer);
        Size += Utf8Encode(String + Size, Consume.Codepoint);
    }
    String[Size] = 0;

    return Str8(String, Size);
}

B8 CharIsLower(U8 Char)
{
    return 'a' <= Char && Char <= 'z';
}

U8 CharToUpper(U8 Char)
{
    if(CharIsLower(Char))
        Char += 'A' - 'a';
    return Char;
}

B8 CharIsSlash(U8 Char)
{
    return Char == '/' || Char == '\\';
}

U8 CharToCorrectSlash(U8 Char)
{
    if(CharIsSlash(Char))
        Char = '/';
    return Char;
}

string8 Str8Range(U8 *First, U8 *OnePastLast)
{
    string8 Result;
    Result.String = First;
    Result.Size = (U64)(OnePastLast - First);
    return Result;
}

B8 Str8Match(string8 First, string8 Second, string_match_flags Flags)
{
    B8 Result = 0;
    if(First.Size == Second.Size || (Flags & STRING_MATCH_FLAG_RIGHT_SIDE_SLOPPY))
    {
        B32 CaseInsensitive = (Flags & STRING_MATCH_FLAG_CASE_INSENSITIVE);
        B32 SlashInsensitive = (Flags & STRING_MATCH_FLAG_SLASH_INSENSITIVE);
        U64 Size = Min(First.Size, Second.Size);
        Result = 1;
        for(U64 Char = 0; Char < Size; ++Char)
        {
            U8 at = First.String[Char];
            U8 bt = Second.String[Char];
            if(CaseInsensitive)
            {
                at = CharToUpper(at);
                bt = CharToUpper(bt);
            }
            if(SlashInsensitive)
            {
                at = CharToCorrectSlash(at);
                bt = CharToCorrectSlash(bt);
            }
            if(at != bt)
            {
                Result = 0;
                break;
            }
        }
    }
    return Result;
}

U64 Str8FindNeedle(string8 String, U64 StartPos, string8 Needle, string_match_flags Flags)
{
    U8 *Pos = String.String + StartPos;
    U64 StopOffset = Max(String.Size + 1, Needle.Size) - Needle.Size;
    U8 *StopPos = String.String + StopOffset;
    if(Needle.Size)
    {
        U8 *StringOpl = String.String + String.Size;
        string8 NeedleTail = Str8Skip(Needle, 1);
        string_match_flags AdjustedFlags = Flags | STRING_MATCH_FLAG_RIGHT_SIDE_SLOPPY;
        U8 NeedleFirstCharAdjusted = Needle.String[0];
        if(AdjustedFlags & STRING_MATCH_FLAG_CASE_INSENSITIVE)
            NeedleFirstCharAdjusted = CharToUpper(NeedleFirstCharAdjusted);
        for(;Pos < StopPos; ++Pos)
        {
            U8 HaystackCharAdjusted = *Pos;
            if(AdjustedFlags & STRING_MATCH_FLAG_CASE_INSENSITIVE)
                HaystackCharAdjusted = CharToUpper(HaystackCharAdjusted);
            if(HaystackCharAdjusted == NeedleFirstCharAdjusted)
            {
                if(Str8Match(Str8Range(Pos + 1, StringOpl), NeedleTail, AdjustedFlags))
                    break;
            }
        }
    }
    U64 Result = String.Size;
    if(Pos < StopPos)
        Result = (U64)(Pos - String.String);
    return Result;
}

