unicode_decode Utf8Decode(U8 *String, U64 Max)
{
    unicode_decode Result;
    Result.Increment = 1;
    Result.Codepoint = U32Max;

    U8 Byte = String[0];
    U8 ByteClass = Utf8Class[Byte >> 3];
    switch(ByteClass)
    {
        case 1:
        {
            Result.Codepoint = Byte;
        }break;

        case 2:
        {
            if(2 < Max)
            {
                U8 ContByte = String[1];
                if(Utf8Class[ContByte >> 3] == 0)
                {
                    Result.Codepoint = (Byte & 0x0000001f) << 6;
                    Result.Codepoint |= (ContByte & 0x0000003f);
                    Result.Increment = 2;
                }
            }
        }break;

        case 3:
        {
            if(2 < Max)
            {
                U8 ContByte[2] = {String[1], String[2]};
                if(Utf8Class[ContByte[0] >> 3] == 0 && Utf8Class[ContByte[1] >> 3] == 0)
                {
                    Result.Codepoint = (Byte & 0x0000000f) << 12;
                    Result.Codepoint |= ((ContByte[0] & 0x0000003f) << 6);
                    Result.Codepoint |= (ContByte[1] & 0x0000003f);
                    Result.Increment = 3;
                }
            }
        }break;

        case 4:
        {
            if(3 < Max)
            {
                U8 ContByte[3] = {String[1], String[2], String[3]};
                if(Utf8Class[ContByte[0] >> 3] == 0 &&
                   Utf8Class[ContByte[1] >> 3] == 0 &&
                   Utf8Class[ContByte[2] >> 3] == 0)
                {
                    Result.Codepoint = (Byte & 0x00000007) << 18;
                    Result.Codepoint |= ((ContByte[0] & 0x0000003f) << 12);
                    Result.Codepoint |= ((ContByte[1] & 0x0000003f) << 6);
                    Result.Codepoint |= (ContByte[2] & 0x0000003f);
                    Result.Increment = 4;
                }
            }
        }break;
    }

    return Result;
}

U32 Utf16Encode(U16 *String, U32 Codepoint)
{
    U32 Increment = 1;
    
    if(Codepoint == U32Max)
    {
        String[0] = (U16)'?';
    }
    else if(Codepoint < 0x10000)
    {
        String[0] = (U16)Codepoint;
    }
    else
    {
        U32 V = Codepoint - 0x10000;
        String[0] = SafeCastU16(0xD800 + (V >> 10));
        String[1] = SafeCastU16(0xDC00 + (V & 0x000003ff));
        Increment = 2;
    }

    return Increment;
}

string16 Str16From8(arena *Arena, string8 In)
{
    U64 Cap = In.Size * 2;
    U16 *String = PushArrayNoZero(Arena, U16, Cap + 1);
    U8 *Pointer = In.String;
    U8 *Opl = Pointer + In.Size;
    U64 Size = 0;
    unicode_decode Consume;
    
    for(;Pointer < Opl; Pointer += Consume.Increment)
    {
        Consume = Utf8Decode(Pointer, Opl - Pointer);
        Size += Utf16Encode(String + Size,  Consume.Codepoint);
    }
    String[Size] = 0;

    return Str16(String, Size);
}

string32 Str32From8(arena *Arena, string8 In)
{
    U64 Cap = In.Size;
    U32 *String = PushArrayNoZero(Arena, U32, Cap + 1);
    U8 *Pointer = In.String;
    U8 *Opl = Pointer + In.Size;
    U64 Size = 0;
    unicode_decode Consume;

    for(;Pointer < Opl; Pointer += Consume.Increment, ++Size)
    {
        Consume = Utf8Decode(Pointer, Opl - Pointer);
        String[Size] = Consume.Codepoint;
    }
    String[Size] = 0;

    return Str32(String, Size);
}
